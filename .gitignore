# =========================
# 实验室系统自定义忽略规则
# =========================

# 1. 后端 (FastAPI & Python)
backend/__pycache__/
backend/.venv/
*.pyc
*.pyo

# 2. 部署与运维敏感数据
deploy/backups/
deploy/.env.*
database_dumps/

