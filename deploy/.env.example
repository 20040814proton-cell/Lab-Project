# Copy this file to deploy/.env.prod and fill real values.
# Do not commit deploy/.env.prod.

# Caddy site host
# - Use your domain in production, e.g. lab.example.com
# - Use :80 for temporary IP-only HTTP mode
CADDY_SITE_HOST=lab.example.com

# Backend runtime
LAB_MONGO_URI=mongodb://mongo:27017
LAB_MONGO_DB=lab_ecosystem
LAB_JWT_SECRET=change_me_to_a_long_random_secret
LAB_CORS_ORIGINS=https://lab.example.com
LAB_STATIC_DIR=static
